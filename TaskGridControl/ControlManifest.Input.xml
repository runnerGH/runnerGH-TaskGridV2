<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="Contoso" constructor="TaskGridControl"
           version="1.0.0" display-name-key="Task Grid Control"
           description-key="Editable hierarchical task grid"
           control-type="standard">

    <data-set name="TaskDataSet" display-name-key="Task Dataset">
      <property-set name="taskName"         display-name-key="Task Name"
                    of-type="SingleLine.Text"      usage="bound" required="true" />
      <property-set name="parentTaskId"     display-name-key="Parent Task"
                    of-type="Lookup.Simple"        usage="bound" required="false" />
      <property-set name="startDate"        display-name-key="Start Date"
                    of-type="DateAndTime.DateOnly" usage="bound" required="false" />
      <property-set name="endDate"          display-name-key="End Date"
                    of-type="DateAndTime.DateOnly" usage="bound" required="false" />
      <property-set name="pctDone"          display-name-key="% Complete"
                    of-type="Decimal"              usage="bound" required="false" />
      <property-set name="isSummary"        display-name-key="Is Summary"
                    of-type="TwoOptions"           usage="bound" required="false" />
      <property-set name="costCategory"     display-name-key="Cost Category"
                    of-type="OptionSet"            usage="bound" required="false" />
      <property-set name="srcService"       display-name-key="SRC Service"
                    of-type="Lookup.Simple"        usage="bound" required="false" />
      <property-set name="fiscalYear"       display-name-key="Fiscal Year"
                    of-type="Lookup.Simple"        usage="bound" required="false" />
      <property-set name="quantity"         display-name-key="Effort"
                    of-type="Decimal"              usage="bound" required="false" />
      <property-set name="unitRate"         display-name-key="Unit Rate"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="unit"             display-name-key="Unit"
                    of-type="SingleLine.Text"      usage="bound" required="false" />
      <property-set name="frequency"        display-name-key="Frequency"
                    of-type="SingleLine.Text"      usage="bound" required="false" />
      <property-set name="plannedCost"      display-name-key="Planned Cost"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="fixedCost"        display-name-key="Fixed Cost"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="totalPlannedCost" display-name-key="Total Planned Cost"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="actualCost"       display-name-key="Actual Cost"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="remainingCost"    display-name-key="Remaining Cost"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="earnedValue"      display-name-key="Earned Value"
                    of-type="Currency"             usage="bound" required="false" />
      <property-set name="actualFixedCost"  display-name-key="Actual Fixed Cost"
                    description-key="Actual Fixed Cost" of-type="Currency"
                    usage="bound"                                required="false" />
      <property-set name="totalActualCost"  display-name-key="Total Actual Cost"
                    description-key="Total Actual Cost" of-type="Currency"
                    usage="bound"                                required="false" />                   
    </data-set>
    <resources>
      <code path="index.ts" order="1" />
    </resources>
  </control>
</manifest>